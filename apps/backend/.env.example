AZURE_DEVOPS_ORG=your-organization-name
AZURE_DEVOPS_PAT=your-personal-access-token
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
CACHE_TTL_GROUPS=300
CACHE_TTL_USERS=300
CACHE_TTL_ACLS=120
# TRACE | DEBUG | INFO | WARN | ERROR (defaults: production=INFO, development=DEBUG)
LOG_LEVEL=DEBUG
# json | pretty (defaults: production=json, development=pretty)
LOG_FORMAT=pretty
