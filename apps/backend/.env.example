# Optional: fixed org/PAT for the API process. If omitted, users connect via the UI
# (POST /api/session/connect) and credentials live in an HttpOnly session cookie.
# AZURE_DEVOPS_ORG=
# AZURE_DEVOPS_PAT=
PORT=3001
NODE_ENV=development
# Must match the browser origin when using credentials: "include" from the SPA
CORS_ORIGIN=http://localhost:5173
# SESSION_COOKIE_NAME=aclara_sid
# SESSION_MAX_AGE_SECONDS=86400
CACHE_TTL_GROUPS=300
CACHE_TTL_USERS=300
CACHE_TTL_ACLS=120
# TRACE | DEBUG | INFO | WARN | ERROR (defaults: production=INFO, development=DEBUG)
LOG_LEVEL=DEBUG
# json | pretty (defaults: production=json, development=pretty)
LOG_FORMAT=pretty
